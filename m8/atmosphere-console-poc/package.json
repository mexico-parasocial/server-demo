{
  "name": "atmosphere-console-poc",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "broker:start": "tsx server/index.ts",
    "broker:test": "node --test --experimental-strip-types server/tests/*.test.ts",
    "broker:typecheck": "tsc -p server/tsconfig.json --noEmit",
    "typecheck": "tsc --noEmit && npm run broker:typecheck"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "better-sqlite3": "^12.8.0",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/react": "~19.1.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
