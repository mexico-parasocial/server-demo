{
  "lexicon": 1,
  "id": "com.pdsmoover.backup.getRepoStatus",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get the status of a backup for a repo. Expected to be implemented by a PDS MOOver back up instance.",
      "parameters": {
        "type": "params",
        "required": [
          "did"
        ],
        "properties": {
          "did": {
            "type": "string",
            "format": "did",
            "description": "The DID of the repo."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "did",
            "active",
            "createdAt"
          ],
          "properties": {
            "did": {
              "type": "string",
              "format": "did"
            },
            "active": {
              "type": "boolean"
            },
            "estimatedBackupSize": {
              "type": "integer",
              "description": "Optional field, the current estimated size of the repo backup in bytes."
            },
            "blobCount": {
              "type": "integer",
              "description": "Optional field, the total number of blobs in the repo backup."
            },
            "missingBlobCount": {
              "type": "integer",
              "description": "Optional field, if set to zero no missing blobs were found. If set to a number greater than zero, the number of missing blobs found from a backup and getting 404 on getBlob.."
            },
            "rev": {
              "type": "string",
              "format": "tid",
              "description": "Optional field, the current rev of the repo backup. If empty there's not a backup"
            },
            "source": {
              "type": "string",
              "description": "Optional field, the current PDS or PDS like source of the backup."
            },
            "lastBackup": {
              "type": "string",
              "format": "datetime",
              "description": "Date of the last backup."
            },
            "createdAt": {
              "type": "string",
              "format": "datetime",
              "description": "Date the backups were created."
            }
          }
        }
      },
      "errors": [
        {
          "name": "RepoNotFound"
        }
      ]
    }
  }
}