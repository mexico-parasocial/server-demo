{
  "lexicon": 1,
  "id": "com.pdsmoover.admin.removeRepo",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Admin authenticated. Removes a repo from being backed up.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "did"
          ],
          "properties": {
            "did": {
              "type": "string",
              "format": "did",
              "description": "The did of the repo to remove"
            }
          }
        }
      },
      "errors": [
        {
          "name": "NotFound"
        },
        {
          "name": "NotAuthorized"
        }
      ]
    }
  }
}