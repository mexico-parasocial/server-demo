{
  "lexicon": 1,
  "id": "com.pdsmoover.admin.removePds",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Admin authenticated. Removes an entire PDS from being backed up. If a user signed up not with the PDS, they will not be removed.",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "hostname"
          ],
          "properties": {
            "hostname": {
              "type": "string",
              "description": "Hostname of the current the PDS"
            }
          }
        }
      },
      "errors": [
        {
          "name": "NotFound"
        },
        {
          "name": "NotAuthorized"
        },
        {
          "name": "NotAValidPDS"
        }
      ]
    }
  }
}