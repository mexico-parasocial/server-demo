{
  "lexicon": 1,
  "id": "com.pdsmoover.admin.requestPdsBackup",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Admin authenticated. Will take a pds_host and request a backup for them if they're registered and active",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "hostname"
          ],
          "properties": {
            "hostname": {
              "type": "string",
              "description": "Hostname of the PDS to back up"
            }
          }
        }
      },
      "errors": [
        {
          "name": "NotFound"
        },
        {
          "name": "NotAuthorized"
        }
      ]
    }
  }
}