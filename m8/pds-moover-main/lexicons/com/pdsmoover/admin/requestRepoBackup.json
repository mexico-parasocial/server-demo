{
  "lexicon": 1,
  "id": "com.pdsmoover.admin.requestRepoBackup",
  "defs": {
    "main": {
      "type": "procedure",
      "description": "Admin authenticated. Will take a did and request a backup for that repo if they're registered and active",
      "input": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": [
            "did"
          ],
          "properties": {
            "did": {
              "type": "string",
              "description": "did of the repo to back up"
            }
          }
        }
      },
      "errors": [
        {
          "name": "NotFound"
        },
        {
          "name": "NotAuthorized"
        }
      ]
    }
  }
}