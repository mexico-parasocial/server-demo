# Local rehearsal blobstore profile: SeaweedFS S3 gateway.
# Safe for local Mac mini dev/storage drills. Do not use as production default.

STORAGE_PROFILE=seaweed-local

PDS_BLOBSTORE_S3_BUCKET=blobs
PDS_BLOBSTORE_S3_REGION=us-east-1
PDS_BLOBSTORE_S3_ENDPOINT=http://localhost:8333
PDS_BLOBSTORE_S3_ACCESS_KEY_ID=weed
PDS_BLOBSTORE_S3_SECRET_ACCESS_KEY=weed_secret
PDS_BLOBSTORE_S3_FORCE_PATH_STYLE=true

SEAWEEDFS_S3_ENDPOINT=http://localhost:8333
SEAWEEDFS_ACCESS_KEY=weed
SEAWEEDFS_SECRET_KEY=weed_secret
SEAWEEDFS_BUCKET=blobs
SEAWEEDFS_REGION=us-east-1

DEV_ENV_PDS_BLOBSTORE_S3_BUCKET=blobs
DEV_ENV_PDS_BLOBSTORE_S3_REGION=us-east-1
DEV_ENV_PDS_BLOBSTORE_S3_ENDPOINT=http://localhost:8333
DEV_ENV_PDS_BLOBSTORE_S3_FORCE_PATH_STYLE=true
DEV_ENV_PDS_BLOBSTORE_S3_ACCESS_KEY_ID=weed
DEV_ENV_PDS_BLOBSTORE_S3_SECRET_ACCESS_KEY=weed_secret
