{
  "name": "@parasocial/content-schema",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./fixtures/*": "./fixtures/*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "prettier --check \"src/**/*\" \"fixtures/**/*\" package.json tsconfig.json",
    "format": "prettier --write \"src/**/*\" \"fixtures/**/*\" package.json tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'content-schema package has no tests'"
  },
  "dependencies": {
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
