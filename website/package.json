{
	"name": "parasocial-web",
	"private": true,
	"version": "0.1.0",
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"dev": "pnpm --filter @parasocial/website dev",
		"dev:website": "pnpm --filter @parasocial/website dev",
		"dev:docs": "pnpm --filter @parasocial/website dev",
		"dev:landing": "pnpm --filter @parasocial/landing dev",
		"build:site": "pnpm --filter @parasocial/website build",
		"build:landing": "pnpm --filter @parasocial/landing build",
		"upload:android-apk": "sh ./scripts/upload-android-apk.sh",
		"deploy:site": "pnpm build:site && sh -c 'test -n \"$CLOUDFLARE_PAGES_PROJECT\" || { echo \"Set CLOUDFLARE_PAGES_PROJECT\"; exit 1; }; pnpm dlx wrangler@latest pages deploy apps/website/build --project-name \"$CLOUDFLARE_PAGES_PROJECT\"'",
		"build": "pnpm -r build",
		"check": "pnpm -r check",
		"lint": "pnpm -r lint",
		"format": "pnpm -r format",
		"test": "pnpm -r test"
	}
}
