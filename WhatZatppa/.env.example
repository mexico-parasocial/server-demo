# PARA Production Environment Variables
# Copy to .env and fill in ALL values before launching.
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# =============================================================================
# INFRASTRUCTURE
# =============================================================================

POSTGRES_USER=pg
POSTGRES_PASSWORD=<32-char-random-hex>
POSTGRES_DB=para

# =============================================================================
# PDS (Personal Data Server) — para-pds container
# =============================================================================

PDS_HOSTNAME=pds.para-g0v.app
PDS_PORT=2583

# Database (PostgreSQL required for production)
PDS_DB_POSTGRES_URL=postgres://pg:<password>@postgres:5432/para

# Blob storage (Cloudflare R2)
# Get your credentials from Cloudflare Dashboard → R2 → Manage R2 API Tokens
PDS_BLOBSTORE_S3_BUCKET=para-production
PDS_BLOBSTORE_S3_REGION=auto
PDS_BLOBSTORE_S3_ENDPOINT=https://1602cb19f70d915d7bc4216d52a86cae.r2.cloudflarestorage.com
PDS_BLOBSTORE_S3_ACCESS_KEY_ID=<r2-access-key-id>
PDS_BLOBSTORE_S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
PDS_BLOBSTORE_S3_FORCE_PATH_STYLE=true

# Signing keys — generate with: openssl rand -hex 32
PDS_REPO_SIGNING_KEY_K256_PRIVATE_KEY_HEX=
PDS_PLC_ROTATION_KEY_K256_PRIVATE_KEY_HEX=

# AppView signing key — required by bsky/api.js
BSKY_SERVICE_SIGNING_KEY=

# Secrets — high-entropy, rotate regularly
PDS_DPOP_SECRET=
PDS_JWT_SECRET=
PDS_ADMIN_PASSWORD=<strong-admin-password>

# External services
PDS_DID_PLC_URL=https://plc.directory
PDS_BSKY_APP_VIEW_URL=https://appview.para-g0v.app
PDS_BSKY_APP_VIEW_DID=did:web:appview.para-g0v.app
PDS_CRAWLERS=https://bsky.network

# Rate limiting
PDS_RATE_LIMITS_ENABLED=true
PDS_RATE_LIMIT_BYPASS_KEY=<random-hex>

# OAuth provider branding
PDS_OAUTH_PROVIDER_NAME="PARA"
PDS_OAUTH_PROVIDER_PRIMARY_COLOR="#48267F"
PDS_OAUTH_PROVIDER_HOME_LINK=https://para.social
PDS_OAUTH_PROVIDER_TOS_LINK=https://para.social/tos
PDS_OAUTH_PROVIDER_POLICY_LINK=https://para.social/privacy

# Registration
PDS_INVITE_REQUIRED=1

# =============================================================================
# AppView (bsky) — para-bsky container
# =============================================================================

BSKY_SERVER_DID=did:web:appview.para.social

# GrowthBook feature flags (optional — backend SDK)
# BSKY_GROWTHBOOK_API_HOST=https://cdn.growthbook.io
# BSKY_GROWTHBOOK_CLIENT_KEY=sdk-xxxxxxxxxxxxxxxx
BSKY_SERVICE_SIGNING_KEY=<32-char-hex>
ADMIN_PASSWORDS=<comma-separated-passwords>
ADMIN_DIDS=<comma-separated-admin-dids>

# Internal service mesh
DATAPLANE_URLS=http://dataplane:2585
BSYNC_URL=http://bsync:2586

# =============================================================================
# Ozone (Moderation) — para-ozone container
# =============================================================================

OZONE_SERVER_DID=did:web:ozone.para-g0v.app
OZONE_ADMIN_DIDS=<comma-separated-admin-dids>
OZONE_DB_POOL_SIZE=10
OZONE_DB_POOL_MAX_USES=100
OZONE_DB_POOL_IDLE_TIMEOUT_MS=30000

# =============================================================================
# bsync — para-bsync container
# =============================================================================

BSYNC_SERVER_DID=did:web:bsync.para.social
BSYNC_DB_POOL_SIZE=10
BSYNC_DB_POOL_MAX_USES=100
BSYNC_DB_POOL_IDLE_TIMEOUT_MS=30000

# =============================================================================
# PARA Frontend (mobile app build-time vars)
# =============================================================================

# Expo / EAS
EXPO_PUBLIC_ENV=production
EXPO_PUBLIC_DEFAULT_SERVICE=https://pds.para.social
EXPO_PUBLIC_RELEASE_VERSION=1.0.0

# Sentry (crash reporting)
SENTRY_AUTH_TOKEN=<sentry-auth-token>
SENTRY_ORG=<sentry-org>
SENTRY_PROJECT=<sentry-project>

# Google Maps (required for geolocation features)
GOOGLE_MAPS_IOS_API_KEY=<google-maps-ios-key>
GOOGLE_MAPS_ANDROID_API_KEY=<google-maps-android-key>

# =============================================================================
# Matrix Homeserver (community deliberation)
# =============================================================================

MATRIX_SERVER_NAME=matrix.para-g0v.app
MATRIX_DOMAIN=chat.para-g0v.app
MATRIX_DB_NAME=matrix

# Create a Synapse admin user, then generate an access token:
#   docker exec -it para-matrix-synapse register_new_matrix_user -c /data/homeserver.yaml -a -u admin -p <password>
#   curl -XPOST -d '{"type":"m.login.password", "user":"admin", "password":"<password>"}' http://localhost:8008/_matrix/client/v3/login
# Then set the access_token value here:
MATRIX_ADMIN_TOKEN=<synapse-admin-access-token>

# Bridge firehose source (defaults to local PDS)
# PDS_FIREHOSE_URL=wss://pds.para.social/xrpc/com.atproto.sync.subscribeRepos

# M8 Identity Manager API used to authenticate Matrix bridge API callers.
# Use http://host.docker.internal:8787/v1 from Docker Desktop, or an internal
# service URL in production.
M8_BASE_URL=http://host.docker.internal:8787/v1

# Bridge log level
# BRIDGE_LOG_LEVEL=info

# =============================================================================
# OPTIONAL / ADVANCED
# =============================================================================

# Feed generator (post-launch)
# FEEDGEN_DID=did:web:feeds.para-g0v.app
# FEEDGEN_HOST=https://feeds.para.social

# PLC directory (only change if self-hosting PLC)
# PLC_HOSTNAME=plc.para-g0v.app

# =============================================================================
# R2 Blobstore (for migration scripts)
# =============================================================================
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_ENDPOINT=https://1602cb19f70d915d7bc4216d52a86cae.r2.cloudflarestorage.com
R2_BUCKET=para-production
