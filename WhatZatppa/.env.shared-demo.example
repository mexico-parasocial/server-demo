# Copy to .env.shared-demo and adjust for your local demo host.
#
# The persistent make targets load this file with ENV=shared-demo.

# Public identity knobs. For local-only development, the defaults are fine.
DEV_ENV_PDS_HOSTNAME=localhost
DEV_ENV_BSKY_PUBLIC_URL=http://localhost:2584
DEV_ENV_ENABLE_DID_DOC_WITH_SESSION=true

# Fixed host storage. These defaults are also applied by the Makefile if unset.
DEV_ENV_PDS_DATA_DIRECTORY=
DEV_ENV_PDS_BLOBSTORE_DIRECTORY=

# Set these to 1 if you want to keep existing data untouched on startup.
DEV_ENV_SKIP_MOCK_SETUP=0
DEV_ENV_SKIP_PARA_DEMO_SEED=0

# Stable schema name for AppView/Ozone tables in the persistent Postgres volume.
DB_POSTGRES_SCHEMA=shared_demo
