{
  "lexicon": 1,
  "id": "com.para.raq.axisVote",
  "defs": {
    "main": {
      "type": "record",
      "description": "A vote on a community-defined RAQ axis, signaling support for its inclusion.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["axisId", "createdAt"],
        "properties": {
          "axisId": {
            "type": "string",
            "maxLength": 64,
            "description": "Reference to the community axis being voted on"
          },
          "value": {
            "type": "integer",
            "minimum": -1,
            "maximum": 1,
            "description": "Vote direction: -1 oppose, 0 neutral, 1 support"
          },
          "createdAt": { "type": "string", "format": "datetime" }
        }
      }
    }
  }
}
