{
  "lexicon": 1,
  "id": "com.para.raq.getUserAlignment",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a user's public RAQ alignment.",
      "parameters": {
        "type": "params",
        "required": ["did"],
        "properties": {
          "did": { "type": "string", "format": "did" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["assessment"],
          "properties": {
            "assessment": { "type": "ref", "ref": "#assessmentView" }
          }
        }
      },
      "errors": [{ "name": "NotFound" }]
    },
    "assessmentView": {
      "type": "object",
      "required": ["results", "compass", "ideology"],
      "properties": {
        "results": {
          "type": "array",
          "items": { "type": "ref", "ref": "com.para.raq.defs#axisResult" }
        },
        "compass": {
          "type": "ref",
          "ref": "com.para.raq.defs#compassPosition"
        },
        "ideology": { "type": "ref", "ref": "com.para.raq.defs#ideologyMatch" },
        "secondaryIdeology": {
          "type": "ref",
          "ref": "com.para.raq.defs#ideologyMatch"
        },
        "partyMatches": {
          "type": "array",
          "items": { "type": "ref", "ref": "com.para.raq.defs#partyMatch" }
        },
        "completedAt": { "type": "string", "format": "datetime" }
      }
    }
  }
}
