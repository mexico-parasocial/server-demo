{
  "lexicon": 1,
  "id": "com.para.collection.listCollections",
  "defs": {
    "main": {
      "type": "query",
      "description": "List policy collections for the authenticated user.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["collections"],
          "properties": {
            "cursor": { "type": "string" },
            "collections": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "com.para.collection.defs#collectionView"
              }
            }
          }
        }
      }
    }
  }
}
