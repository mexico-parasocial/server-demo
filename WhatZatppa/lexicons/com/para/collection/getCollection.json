{
  "lexicon": 1,
  "id": "com.para.collection.getCollection",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a single policy collection by ID.",
      "parameters": {
        "type": "params",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["collection"],
          "properties": {
            "collection": {
              "type": "ref",
              "ref": "com.para.collection.defs#collectionView"
            }
          }
        }
      },
      "errors": [{ "name": "NotFound" }]
    }
  }
}
