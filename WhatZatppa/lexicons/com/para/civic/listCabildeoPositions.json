{
  "lexicon": 1,
  "id": "com.para.civic.listCabildeoPositions",
  "defs": {
    "main": {
      "type": "query",
      "description": "List indexed positions for a Cabildeo with optional stance filter.",
      "parameters": {
        "type": "params",
        "required": ["cabildeo"],
        "properties": {
          "cabildeo": {
            "type": "string",
            "format": "at-uri"
          },
          "stance": {
            "type": "string",
            "knownValues": ["for", "against", "amendment"]
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["positions"],
          "properties": {
            "cursor": { "type": "string" },
            "positions": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "com.para.civic.defs#positionView"
              }
            }
          }
        }
      }
    }
  }
}
