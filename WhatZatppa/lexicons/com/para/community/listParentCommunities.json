{
  "lexicon": 1,
  "id": "com.para.community.listParentCommunities",
  "defs": {
    "main": {
      "type": "query",
      "description": "Lists parent communities for a child community.",
      "parameters": {
        "type": "params",
        "required": ["communityUri"],
        "properties": {
          "communityUri": { "type": "string", "format": "at-uri" },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50
          },
          "cursor": { "type": "string" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "ref",
          "ref": "com.para.community.listCommunityRelations#output"
        }
      }
    }
  }
}
