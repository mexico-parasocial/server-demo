{
  "lexicon": 1,
  "id": "com.para.community.vote",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["proposal", "community", "voter", "signal"],
        "properties": {
          "proposal": {
            "type": "string",
            "format": "at-uri",
            "description": "URI of the proposal being voted on"
          },
          "community": {
            "type": "string",
            "format": "at-uri"
          },
          "voter": {
            "type": "string",
            "format": "did"
          },
          "signal": {
            "type": "integer",
            "minimum": -3,
            "maximum": 3,
            "description": "Base political signal: -3 strong against … +3 strong for. 0 = abstain."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
