{
  "lexicon": 1,
  "id": "com.para.community.deliberationVote",
  "defs": {
    "main": {
      "type": "record",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["deliberation", "voter", "direction"],
        "properties": {
          "deliberation": {
            "type": "string",
            "format": "at-uri"
          },
          "voter": {
            "type": "string",
            "format": "did"
          },
          "direction": {
            "type": "string",
            "enum": ["agree", "disagree", "pass"]
          },
          "voteNullifier": {
            "type": "string",
            "maxLength": 128,
            "description": "Privacy-preserving one-person-one-vote nullifier for this deliberation statement, issued by m8."
          },
          "eligibilityProofRef": {
            "type": "string",
            "maxLength": 512,
            "description": "Opaque reference to the m8 eligibility/nullifier proof used to cast this vote."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
