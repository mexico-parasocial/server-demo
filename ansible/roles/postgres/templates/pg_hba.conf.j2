# PARA PostgreSQL Access Control
# ONLY internal Docker network access allowed. No public exposure.

# Local connections (same container)
local   all             all                                     trust
host    all             all             127.0.0.1/32            trust
host    all             all             ::1/128                 trust

# Docker Swarm overlay network (internal only)
host    {{ postgres_db }}    {{ postgres_user }}    10.0.0.0/8              scram-sha-256
host    {{ postgres_db }}    {{ postgres_user }}    172.16.0.0/12           scram-sha-256
host    {{ postgres_db }}    {{ postgres_user }}    192.168.0.0/16          scram-sha-256

# Reject everything else
host    all             all             0.0.0.0/0               reject
host    all             all             ::/0                    reject
