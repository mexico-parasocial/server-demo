#!/bin/bash
set -euo pipefail

# PARA PostgreSQL Restore Script
# WARNING: This drops the existing database. Use only in emergencies.

PG_USER="{{ postgres_user }}"
PG_PASS="{{ postgres_password }}"
PG_DB="{{ postgres_db }}"
PG_HOST="localhost"
PG_PORT="5432"

if [ $# -eq 0 ]; then
  echo "Usage: $0 <path-to-backup.dump.gz>"
  echo ""
  echo "Available local backups:"
  ls -lh {{ para_deploy_dir }}/postgres/backups/para_*.sql.gz 2>/dev/null || echo "  (none found)"
  echo ""
  echo "Download from S3 first if needed:"
  echo "  mc cp para-backup/BUCKET/postgres/daily/para_YYYYMMDD_HHMMSS.sql.gz {{ para_deploy_dir }}/postgres/backups/"
  exit 1
fi

BACKUP_FILE="$1"
export PGPASSWORD="$PG_PASS"

if [ ! -f "$BACKUP_FILE" ]; then
  echo "ERROR: Backup file not found: $BACKUP_FILE"
  exit 1
fi

echo "⚠️  THIS WILL DROP DATABASE '$PG_DB' AND RECREATE IT."
echo "   Backup file: $BACKUP_FILE"
read -p "   Type RESTORE to continue: " CONFIRM

if [ "$CONFIRM" != "RESTORE" ]; then
  echo "Aborted."
  exit 1
fi

echo "Stopping services that depend on Postgres..."
docker service scale para_pds=0 para_appview=0 para_ozone=0 2>/dev/null || true
sleep 5

echo "Dropping and recreating database..."
dropdb -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" --if-exists "$PG_DB"
createdb -h "$PG_HOST" -p "$PG_PORT" -U "$PG_USER" "$PG_DB"

echo "Restoring from backup..."
if [[ "$BACKUP_FILE" == *.gz ]]; then
  gunzip -c "$BACKUP_FILE" | pg_restore \
    -h "$PG_HOST" \
    -p "$PG_PORT" \
    -U "$PG_USER" \
    -d "$PG_DB" \
    --no-owner \
    --no-acl \
    --verbose \
    2>&1
else
  pg_restore \
    -h "$PG_HOST" \
    -p "$PG_PORT" \
    -U "$PG_USER" \
    -d "$PG_DB" \
    --no-owner \
    --no-acl \
    --verbose \
    "$BACKUP_FILE" \
    2>&1
fi

echo "Restarting services..."
docker service scale para_pds=1 para_appview={{ appview_replicas | default(2) }} para_ozone=1

echo "✅ Restore complete. Verify with: docker service logs para_pds"
